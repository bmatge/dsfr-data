{
  "name": "dsfr-data",
  "version": "0.3.3",
  "description": "Bibliothèque de Web Components de dataviz pour sites gouvernementaux",
  "type": "module",
  "main": "dist/dsfr-data.umd.js",
  "module": "dist/dsfr-data.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/dsfr-data.esm.js",
      "require": "./dist/dsfr-data.umd.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/dsfr-data.core.esm.js",
      "require": "./dist/dsfr-data.core.umd.js"
    },
    "./world-map": {
      "import": "./dist/dsfr-data.world-map.esm.js",
      "require": "./dist/dsfr-data.world-map.umd.js"
    }
  },
  "files": [
    "dist/dsfr-data.*.js",
    "dist/data/"
  ],
  "workspaces": [
    "packages/*",
    "apps/*",
    "server"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite-node scripts/build-lib.ts && vite-node scripts/build-skills-json.ts",
    "build:shared": "npm run build --workspace=@dsfr-data/shared",
    "build:apps": "npm run build --workspace=@dsfr-data/app-favorites && npm run build --workspace=@dsfr-data/app-playground && npm run build --workspace=@dsfr-data/app-sources && npm run build --workspace=@dsfr-data/app-builder-ia && npm run build --workspace=@dsfr-data/app-builder && npm run build --workspace=@dsfr-data/app-dashboard && npm run build --workspace=@dsfr-data/app-monitoring && npm run build --workspace=@dsfr-data/app-grist-widgets",
    "build:all": "npm run build:shared && npm run build && npm run build:apps",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:all && npm run build:app && tauri build",
    "build:app": "node scripts/build-app.js",
    "build:server": "npm run build --workspace=@dsfr-data/server",
    "dev:server": "npm run dev --workspace=@dsfr-data/server",
    "test:e2e": "playwright test",
    "prepublishOnly": "npm run build:shared && npm run build"
  },
  "keywords": [
    "web-components",
    "dsfr",
    "dataviz",
    "gouvernement",
    "lit"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@gouvfr/dsfr-chart": "^2.0.4",
    "@types/topojson-specification": "^1.0.5",
    "d3-geo": "^3.1.1",
    "lit": "^3.1.0",
    "topojson-client": "^3.1.0",
    "world-atlas": "^2.0.2"
  },
  "overrides": {
    "qs": "6.14.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.0",
    "@types/d3-geo": "^3.1.0",
    "@types/topojson-client": "^3.1.5",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.2",
    "typescript": "^5.3.0",
    "vite": "^6.4.1",
    "vitest": "^3.0.0"
  }
}
