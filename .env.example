# =============================================================================
# gouv-widgets - Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs a votre environnement.
#
#   cp .env.example .env
#
# Les variables prefixees VITE_ sont injectees dans le frontend au build time.
# Les autres sont utilisees par Docker / les scripts de deploiement.
# =============================================================================

# ---------------------------------------------------------------------------
# Domaine de production
# ---------------------------------------------------------------------------
# Nom de domaine sur lequel l'application est deployee.
# Utilise par Traefik (docker-compose.yml) et les scripts de deploiement.
APP_DOMAIN=chartsbuilder.matge.com

# ---------------------------------------------------------------------------
# URL du proxy CORS (build-time)
# ---------------------------------------------------------------------------
# URL de base du proxy CORS pour les appels API en production.
# Si non defini, le fallback est https://${APP_DOMAIN}.
# En dev, cette variable est ignoree (le proxy Vite est utilise).
# VITE_PROXY_URL=https://chartsbuilder.matge.com

# ---------------------------------------------------------------------------
# URL de la librairie JS dans le code genere (build-time)
# ---------------------------------------------------------------------------
# URL de base pour les bundles gouv-widgets dans le code HTML genere.
# Valeurs speciales :
#   "unpkg"    → https://unpkg.com/gouv-widgets/dist
#   "jsdelivr" → https://cdn.jsdelivr.net/npm/gouv-widgets/dist
# Sinon, une URL custom (ex: https://cdn.example.com/dist).
# Si non defini, utilise ${VITE_PROXY_URL}/dist (self-hosted).
# VITE_LIB_URL=unpkg

# ---------------------------------------------------------------------------
# JWT Secret (mode serveur uniquement)
# ---------------------------------------------------------------------------
# Cle secrete pour la signature des tokens JWT (mode serveur avec auth).
# Generee automatiquement par deploy-server.sh si absente.
# JWT_SECRET=

# ---------------------------------------------------------------------------
# Albert IA (Builder IA)
# ---------------------------------------------------------------------------
# Token API pour l'IA Albert (DINUM). Necessaire pour le Builder IA.
# Obtenir un token : https://albert.api.etalab.gouv.fr
# VITE_ALBERT_API_KEY=
